# =============================================================================
# StánekOS - Environment Variables
# =============================================================================
# Zkopíruj tento soubor jako .env a doplň skutečné hodnoty.
# NIKDY necommituj .env do Gitu!
# =============================================================================

# Databáze -------------------------------------------------------------------
DATABASE_URL=postgresql://stanek:zmen_me@localhost:5432/stanek_os
DATABASE_SSL=false

# Stripe ---------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_TERMINAL_LOCATION_ID=tml_xxx

# Kiosk API klíče (jeden per stánek) -----------------------------------------
# Generuj: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KIOSK_API_KEY_1=zmen_me_32_plus_chars_nahodneho_retezce_11111111111
KIOSK_API_KEY_2=zmen_me_32_plus_chars_nahodneho_retezce_22222222222
KIOSK_API_KEY_3=zmen_me_32_plus_chars_nahodneho_retezce_33333333333

# Admin JWT (min 64 znaků každý) ---------------------------------------------
JWT_SECRET=zmen_me_aspon_64_znaku_nahodnych_generuj_pres_crypto_randomBytes_32_hex
JWT_REFRESH_SECRET=jiny_nez_vyse_aspon_64_znaku_nahodnych_generuj_pres_crypto_randomBytes_32_hex

# Telegram -------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Tiskárny (IP per stánek, formát: tcp://IP nebo /dev/usb/lp0) ---------------
PRINTER_STALL_1=tcp://192.168.1.101
PRINTER_STALL_2=tcp://192.168.1.102
PRINTER_STALL_3=tcp://192.168.1.103

# ARES -----------------------------------------------------------------------
ARES_BASE_URL=https://ares.gov.cz/ekonomicke-subjekty-v-be/rest

# Email (volitelné, pro zasílání faktur) ------------------------------------
SENDGRID_API_KEY=
EMAIL_FROM=faktura@tvoje-firma.cz

# Firma (pro doklady) -------------------------------------------------------
COMPANY_NAME=Tvoje Firma s.r.o.
COMPANY_ICO=12345678
COMPANY_DIC=CZ12345678
COMPANY_ADDRESS=Ulice 1, 110 00 Praha 1
COMPANY_PHONE=+420 XXX XXX XXX

# CORS (čárkou oddělené URL kiosku a adminu) --------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# Server --------------------------------------------------------------------
PORT=3001
NODE_ENV=production
