# Kiosk frontend - env
# Zkopíruj jako .env.local a doplň

# URL backendu (necháte prázdné pokud je kiosk na stejné doméně jako backend)
VITE_API_URL=http://localhost:3001

# Kiosk API klíč (z backend/.env KIOSK_API_KEY_1/2/3)
VITE_KIOSK_KEY=

# Stripe simulace pro testování bez reálné čtečky
VITE_STRIPE_SIMULATED=false
